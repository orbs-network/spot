{
    "name": "@orbs-network/spot",
    "version": "2.2.4",
    "mcpName": "io.github.orbs-network/spot",
    "description": "**A DeFi protocol for noncustodial advanced order types on EVM chains.**",
    "homepage": "https://github.com/orbs-network/spot#readme",
    "bugs": {
        "url": "https://github.com/orbs-network/spot/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/orbs-network/spot.git"
    },
    "license": "MIT",
    "author": "danielz@orbs.com",
    "engines": {
        "node": ">=18"
    },
    "bin": {
        "spot-mcp": "./mcp/stdio.mjs"
    },
    "scripts": {
        "fmt": "forge fmt",
        "build": "node ./script/sync-mcp.mjs && forge build --extra-output-files abi",
        "test": "forge test",
        "prepublishOnly": "npm run fmt && npm run build && npm run test"
    },
    "files": [
        "config.json",
        "index.css",
        "index.html",
        "SKILL.md",
        "manifest.json",
        "skill/",
        "script/input/",
        "out/**/*.json",
        "index.js",
        "mcp/",
        "server.json"
    ],
    "main": "index.js",
    "dependencies": {
        "@modelcontextprotocol/sdk": "1.27.1",
        "zod": "4.3.6"
    }
}
