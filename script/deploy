#!/usr/bin/env zsh
set -euo pipefail

CONFIG_FILE=config.json
components=(
  wm
  repermit
  cosigner
  reactor
  executor
  refinery
)

dex=""
verify=false
args=()
typeset -A runtime_env

usage() {
  cat <<'EOF'
Usage: script/deploy [options] [-- forge script args]

Options:
  -d, --dex NAME     Deploy and configure a specific dex (requires CHAIN_ID; auto-deploys core contracts when OWNER is set).
  -v, --verify       Verify configured core contracts.
  -h, --help         Show this help message.
EOF
}

while [[ $# -gt 0 ]]; do
  case $1 in
    --)
      shift
      args+=("$@")
      break
      ;;
    -d|--dex)
      [[ $# -lt 2 || -z $2 ]] && { printf 'error: missing dex name\n' >&2; exit 1; }
      dex=${2:l}
      shift 2
      ;;
    -v|--verify)
      verify=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

require_env_var() {
  local key=$1 value=""
  if [[ -v $key ]]; then
    value=${(P)key}
  fi
  if [[ -z $value ]]; then
    printf 'error: %s is required in the environment\n' "$key" >&2
    exit 1
  fi
}

salt_for() {
  local key=$1 chain=${CHAIN_ID:-}
  jq -r --arg key "$key" --arg chain "$chain" '
    (."*".salt[$key])
    // (if ($chain | length) > 0 then (.[$chain].salt[$key]) else null end)
    // ""
  ' "$CONFIG_FILE"
}

dex_salt_for() {
  local dex=${1:-}
  [[ -z $dex ]] && { printf 'error: missing dex name for salt\n' >&2; exit 1; }
  command -v cast >/dev/null 2>&1 || { printf 'error: cast is required to compute dex salt\n' >&2; exit 1; }
  cast keccak "$dex"
}

update_config() {
  local target=$1 address=$2 tmp=$(mktemp)
  if [[ $target == global:* ]]; then
    jq --indent 4 --arg key "${target#global:}" --arg addr "$address" '
      setpath(["*", $key]; $addr)
    ' "$CONFIG_FILE" >"$tmp"
  else
    local chain dex field
    local IFS=':'
    read -r _ chain dex field <<< "$target"
    jq --indent 4 --arg chain "$chain" --arg dex "$dex" --arg field "$field" --arg addr "$address" '
      setpath([$chain, "dex", $dex, $field]; $addr)
    ' "$CONFIG_FILE" >"$tmp"
  fi
  mv "$tmp" "$CONFIG_FILE"
  printf 'Updated %s -> %s\n\n' "$target" "$address"
}

should_update_config() {
  local broadcast=false debug=false arg
  for arg in "${args[@]}"; do
    case $arg in
      --broadcast) broadcast=true ;;
      --resume) broadcast=true ;;
      --debug) debug=true ;;
    esac
  done
  $broadcast && ! $debug
}

dex_field_for() {
  local chain=$1 dex=$2 field=$3
  jq -r --arg chain "$chain" --arg dex "$dex" --arg field "$field" '
    .[$chain].dex[$dex][$field] // ""
  ' "$CONFIG_FILE"
}

core_field_for() {
  local field=$1
  jq -r --arg field "$field" '
    ."*"[$field] // ""
  ' "$CONFIG_FILE"
}

runtime_env_var_for_target() {
  local target=$1
  case $target in
    global:*)
      printf '%s' "${(U)${target#global:}}"
      ;;
  esac
}

runtime_env_assignments() {
  local -a assignments=()
  local key value
  for key value in ${(kv)runtime_env}; do
    [[ -n $value ]] || continue
    assignments+=("${key}=${value}")
  done
  printf '%s\n' "${assignments[@]}"
}

remember_runtime_address() {
  local target=$1 address=$2 env_var
  env_var=$(runtime_env_var_for_target "$target")
  [[ -n $env_var ]] || return 0
  runtime_env[$env_var]=$address
}

deploy_core_contracts() {
  local key script
  for key in "${components[@]}"; do
    if [[ $key == wm ]]; then
      script=DeployWM
    else
      script="Deploy${(U)key[1,1]}${key[2,-1]}"
    fi
    run "$(salt_for "$key")" "$script" "global:$key"
  done
}

ensure_core_contracts_for_dex() {
  local dex=$1 chain_id=$2
  local key address
  local -a missing=()

  for key in "${components[@]}"; do
    address=$(core_field_for "$key")
    [[ -n $address ]] || missing+=("$key")
  done

  if [[ -n ${OWNER:-} ]]; then
    deploy_core_contracts
    return 0
  fi

  if (( ${#missing[@]} > 0 )); then
    printf 'error: OWNER is required to auto-deploy missing core contracts before deploying dex %s on chain %s; missing config for: %s\n' \
      "$dex" "$chain_id" "${(j:, :)missing}" >&2
    exit 1
  fi
}

run() {
  local salt=$1 script=$2 target=${3:-}
  shift 3

  local -a env_assignments=("$@")
  local -a runtime_assignments=()
  local tmp=$(mktemp) raw_tmp=$(mktemp)
  local load_opts=(-u)
  local runtime_assignment
  [[ -n ${CHAIN_ID:-} ]] && load_opts+=(-c "$CHAIN_ID")

  if [[ -n $salt && $salt != null ]]; then
    env_assignments=("SALT=$salt" "${env_assignments[@]}")
  fi
  while IFS= read -r runtime_assignment; do
    [[ -n $runtime_assignment ]] || continue
    runtime_assignments+=("$runtime_assignment")
  done < <(runtime_env_assignments)
  if (( ${#runtime_assignments[@]} > 0 )); then
    env_assignments=("${runtime_assignments[@]}" "${env_assignments[@]}")
  fi

  local cmd=(load "${load_opts[@]}" "$CONFIG_FILE")
  if (( ${#env_assignments[@]} > 0 )); then
    cmd+=(env "${env_assignments[@]}")
  fi
  cmd+=(forge script "$script" "${args[@]}" --json)

  if ! "${cmd[@]}" >"$raw_tmp"; then
    cat "$raw_tmp"
    rm -f "$tmp" "$raw_tmp"
    return 1
  fi

  grep -E '^[[:space:]]*[\{\[]' "$raw_tmp" > "$tmp" || true
  rm -f "$raw_tmp"

  jq -r '.logs[]?' "$tmp"
  if [[ -n $target ]]; then
    local address=$(jq -r '.returns[]?.value | select(. != null)' "$tmp" | tail -n1)
    if [[ -n $address ]]; then
      remember_runtime_address "$target" "$address"
      if should_update_config; then
        update_config "$target" "$address"
      else
        printf 'Resolved %s -> %s (dry run; config not updated)\n\n' "$target" "$address"
      fi
    fi
  fi

  rm -f "$tmp"
}

deploy_dex() {
  local dex=$1 chain_id=${CHAIN_ID:-}
  if [[ -z $chain_id ]]; then
    printf 'error: CHAIN_ID is required for -d/--dex\n' >&2
    exit 1
  fi

  ensure_core_contracts_for_dex "$dex" "$chain_id"

  local dex_salt
  dex_salt=$(dex_salt_for "$dex")

  local dex_type
  if ! dex_type=$(jq -er --arg chain "$chain_id" --arg dex "$dex" '
      .[$chain].dex[$dex].type
      // error("dex \"" + $dex + "\" is not configured for chain " + $chain)
    ' "$CONFIG_FILE"); then
    exit 1
  fi

  local adapter_type=${dex_type%%:*}
  local script
  case $adapter_type in
    default)
      script=DeployDefaultAdapter
      ;;
    p2)
      script=DeployP2Adapter
      ;;
    paraswap)
      script=DeployParaswapAdapter
      ;;
    universal)
      script=DeployUniversalAdapter
      ;;
    *) printf 'error: unsupported adapter type %s\n' "$dex_type" >&2; exit 1 ;;
  esac

  local adapter_address fee_address
  adapter_address=$(jq -r --arg chain "$chain_id" --arg dex "$dex" '.[$chain].dex[$dex].adapter // ""' "$CONFIG_FILE")
  fee_address=$(jq -r --arg chain "$chain_id" --arg dex "$dex" '.[$chain].dex[$dex].fee // ""' "$CONFIG_FILE")

  if [[ -n $adapter_address ]]; then
    printf 'Adapter already configured for %s on chain %s (%s); skipping deployment\n' "$dex" "$chain_id" "$adapter_address"
  else
    local -a adapter_env=()
    case $adapter_type in
      default|paraswap)
        local router
        router=$(dex_field_for "$chain_id" "$dex" router)
        if [[ -z $router ]]; then
          printf 'error: ROUTER is required for dex %s on chain %s (set config.%s.dex.%s.router)\n' \
            "$dex" "$chain_id" "$chain_id" "$dex" >&2
          exit 1
        fi
        adapter_env=("ROUTER=$router")
        ;;
      p2)
        local router permit2
        router=$(dex_field_for "$chain_id" "$dex" router)
        permit2=$(dex_field_for "$chain_id" "$dex" permit2)
        if [[ -z $router ]]; then
          printf 'error: ROUTER is required for dex %s on chain %s (set config.%s.dex.%s.router)\n' \
            "$dex" "$chain_id" "$chain_id" "$dex" >&2
          exit 1
        fi
        if [[ -z $permit2 ]]; then
          printf 'error: PERMIT2 is required for p2 dex %s on chain %s (set config.%s.dex.%s.permit2)\n' \
            "$dex" "$chain_id" "$chain_id" "$dex" >&2
          exit 1
        fi
        adapter_env=("ROUTER=$router" "PERMIT2=$permit2")
        ;;
      universal)
        ;;
    esac

    run "$dex_salt" "$script" "dex:${chain_id}:${dex}:adapter" "${adapter_env[@]}"
  fi

  if [[ -n $fee_address ]]; then
    printf 'Fee already configured for %s on chain %s (%s); skipping deployment\n' "$dex" "$chain_id" "$fee_address"
  else
    run "$dex_salt" DeployRefinery "dex:${chain_id}:${dex}:fee"
  fi
}

verify_contracts() {
  local load_opts=(-u)
  [[ -n ${CHAIN_ID:-} ]] && load_opts+=(-c "$CHAIN_ID")

  typeset -A targets=(
    [wm]=WM
    [repermit]=RePermit
    [cosigner]=Cosigner
    [executor]=Executor
    [reactor]=OrderReactor
    [refinery]=Refinery
  )

  for key contract in ${(kv)targets}; do
    local env_var=${(U)key}
    local script='addr=${'"${env_var}"':-}; if [[ -z $addr ]]; then printf "warning: env var %s not set; skipping verify for %s\n" '"${env_var}"' '"${contract}"' >&2; exit 0; fi; forge v "$addr" '"${contract}"' "$@"'
    load "${load_opts[@]}" "$CONFIG_FILE" sh -c "$script" _ "${args[@]}"
  done

  verify_adapter_contracts "${load_opts[@]}"
}

adapter_contract_for() {
  local adapter_type=$1
  case $adapter_type in
    default) printf 'DefaultDexAdapter' ;;
    p2) printf 'P2DexAdapter' ;;
    paraswap) printf 'ParaswapDexAdapter' ;;
    universal) printf 'UniversalAdapter' ;;
    *) return 1 ;;
  esac
}

verify_adapter_contracts() {
  local -a load_opts=("$@")
  local chain_id=${CHAIN_ID:-}
  if [[ -z $chain_id ]]; then
    printf 'warning: CHAIN_ID not set; skipping adapter verification\n' >&2
    return 0
  fi

  local rows
  rows=$(jq -r --arg chain "$chain_id" '
    (.[$chain].dex // {})
    | to_entries[]
    | select((.value.adapter // "") != "")
    | [.key, (.value.type // ""), .value.adapter]
    | @tsv
  ' "$CONFIG_FILE")

  [[ -z $rows ]] && return 0

  local dex type addr adapter_type contract script
  while IFS=$'\t' read -r dex type addr; do
    [[ -z $dex || -z $type || -z $addr ]] && continue
    adapter_type=${type%%:*}
    if ! contract=$(adapter_contract_for "$adapter_type"); then
      printf 'warning: unsupported adapter type %s for dex %s; skipping adapter verify\n' "$type" "$dex" >&2
      continue
    fi
    script='addr=$1; contract=$2; dex=$3; shift 3; printf "Verifying adapter for %s (%s) at %s\n" "$dex" "$contract" "$addr"; forge v "$addr" "$contract" "$@"'
    load "${load_opts[@]}" "$CONFIG_FILE" sh -c "$script" _ "$addr" "$contract" "$dex" "${args[@]}"
  done <<< "$rows"
}

if $verify; then
  verify_contracts
  exit 0
fi

if [[ -n $dex ]]; then
  deploy_dex "$dex"
  exit 0
fi

require_env_var OWNER

deploy_core_contracts
